# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Development: http://localhost:5173
# Production:  https://yourdomain.com,https://www.yourdomain.com
CLIENT_URLS=http://localhost:5173

# ── Supabase ──────────────────────────────────────────────────────────────────
# All three values are available in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...                    # "anon" public key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...            # "service_role" secret key (keep private!)
# JWT secret: Supabase Dashboard → Project Settings → API → JWT Settings
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Available in: Cloudinary Dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret            # Keep private!

# ── Upload tuning (optional) ──────────────────────────────────────────────────
# Maximum file size in MB accepted by the upload endpoint. Default: 5
MAX_FILE_SIZE_MB=5
# Cloudinary SDK timeout in milliseconds. Default: 120000 (2 minutes)
# Lower this (e.g. 30000) in production for faster fail-fast on large files.
# CLOUDINARY_TIMEOUT_MS=120000
